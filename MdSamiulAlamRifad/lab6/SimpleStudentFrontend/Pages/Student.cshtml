@page
@model SimpleStudentFrontend.Pages.StudentModel
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Simple Student Frontend</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 40px;
            background: #f5f7fb;
            color: #222;
        }
        .card {
            max-width: 800px;
            background: white;
            border-radius: 12px;
            padding: 24px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.08);
        }
        h1 { margin-top: 0; }
        .label { font-weight: bold; display: inline-block; width: 150px; }
        .row { margin: 10px 0; }
        .ok { color: #0a7d2c; font-weight: bold; }
        .error { color: #b00020; font-weight: bold; }
        .meta { color: #555; margin-top: 24px; font-size: 14px; }
    </style>
</head>
<body>
    <div class="card">
        <h1>Simple Student Frontend</h1>
        <p>This page calls <strong>SimpleStudentApi</strong> from a separate Docker container.</p>

        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <p class="error">Error: @Model.ErrorMessage</p>
        }
        else if (Model.ApiStudent is not null)
        {
            <div class="row"><span class="label">FirstName:</span> @Model.ApiStudent.FirstName</div>
            <div class="row"><span class="label">LastName:</span> @Model.ApiStudent.LastName</div>
            <div class="row"><span class="label">Status:</span> <span class="ok">@Model.ApiStudent.Status</span></div>
            <div class="row"><span class="label">Message:</span> @Model.ApiStudent.Message</div>
            <div class="row"><span class="label">Environment:</span> @Model.ApiStudent.Environment</div>
            <div class="row"><span class="label">Timestamp UTC:</span> @Model.ApiStudent.TimestampUtc.ToString("u")</div>
        }
        else
        {
            <p>No API data available.</p>
        }

        <div class="meta">
            Frontend container port: 8080<br />
            API service URL used by frontend: @Model.ApiBaseUrl/api/getStudent
        </div>
    </div>
</body>
</html>
